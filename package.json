  "homepage": "https://www.thatamy.com",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-inclusive-language": "^1.0.3",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "eleventy-plugin-time-to-read": "^1.3.0",
    "markdown-it": "^14.1.0",
    "sass": "^1.55.0"
  }
}
